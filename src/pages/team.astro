---
import Base from '../layouts/Base.astro';
import { team } from '../data/site';
---

<Base title="Meet the Team" description="Meet the occupational therapy team at Adventure Therapy Services in Pakenham. Katherine Stewart, Rainy Streeter-Gillard, and Joan Stanton.">
  <!-- Page Header with wave (matching WP) -->
  <section class="page-header">
    <h1>Meet the Team</h1>
    <div class="header-wave">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320" preserveAspectRatio="none">
        <path fill="#ffffff" fill-opacity="1" d="M0,224L48,240C96,256,192,288,288,256C384,224,480,128,576,80C672,32,768,32,864,69.3C960,107,1056,181,1152,176C1248,171,1344,85,1392,42.7L1440,0L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"/>
      </svg>
    </div>
  </section>

  <section class="team-section">
    <div class="container">
      <!-- First two members side by side (matching WP layout) -->
      <div class="team-grid-two">
        {team.slice(0, 2).map((member) => (
          <div class="team-card">
            <img src={member.image} alt={member.name} class="card-photo" loading="lazy" />
            <h2>{member.name}</h2>
            <p class="card-role">{member.role}</p>
            <p class="card-schedule">
              Work Days: {member.workDays}<br />
              Times: {member.workTimes}
            </p>
            <h4>Special Interest Areas</h4>
            <ul>
              {member.specialInterests.map((interest) => (
                <li>{interest}</li>
              ))}
            </ul>
            <a href={`/team/${member.slug}/`} class="read-more-btn">Read More</a>
          </div>
        ))}
      </div>

      <!-- Third member centered (matching WP layout) -->
      <div class="team-grid-one">
        {team.slice(2).map((member) => (
          <div class="team-card">
            <img src={member.image} alt={member.name} class="card-photo" loading="lazy" />
            <h2>{member.name}</h2>
            <p class="card-role">{member.role}</p>
            <p class="card-schedule">
              Work Days: {member.workDays}<br />
              Times: {member.workTimes}
            </p>
            <h4>Special Interest Areas</h4>
            <ul>
              {member.specialInterests.map((interest) => (
                <li>{interest}</li>
              ))}
            </ul>
            <a href={`/team/${member.slug}/`} class="read-more-btn">Read More</a>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .page-header {
    background: var(--color-primary);
    padding: 3rem 1.5rem 0;
    text-align: center;
    position: relative;
  }
  .page-header h1 {
    font-size: clamp(2rem, 4vw, 2.5rem);
    color: #fff;
    margin-bottom: 0;
  }
  .header-wave {
    line-height: 0;
    margin-top: 1rem;
  }
  .header-wave svg {
    width: 100%;
    height: 100px;
    display: block;
  }

  .team-section {
    padding: 3rem 0 4rem;
  }

  /* Two-column grid for first 2 members */
  .team-grid-two {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  /* Centered single member */
  .team-grid-one {
    display: flex;
    justify-content: center;
  }
  .team-grid-one .team-card {
    max-width: 380px;
  }

  .team-card {
    text-align: left;
  }
  .card-photo {
    width: 100%;
    max-width: 300px;
    height: 300px;
    object-fit: cover;
    object-position: top;
    border-radius: 12px;
    margin-bottom: 1rem;
  }

  .team-card h2 {
    font-size: 1.5rem;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }
  .card-role {
    color: var(--color-text-light);
    font-size: 1rem;
    margin-bottom: 0.75rem;
  }
  .card-schedule {
    font-size: 0.9rem;
    color: var(--color-text);
    margin-bottom: 1rem;
    line-height: 1.5;
  }
  .team-card h4 {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
  .team-card ul {
    padding-left: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .team-card li {
    list-style: disc;
    color: var(--color-text-light);
    line-height: 1.5;
    margin-bottom: 0.25rem;
    font-size: 0.9rem;
  }

  .read-more-btn {
    display: inline-block;
    background: var(--color-primary);
    color: #fff;
    padding: 0.6rem 1.5rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.2s;
  }
  .read-more-btn:hover {
    background: var(--color-primary-dark);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .team-grid-two {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .team-grid-one .team-card {
      max-width: 100%;
    }
  }
</style>
