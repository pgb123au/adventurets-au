---
import Base from '../layouts/Base.astro';
---

<Base title="Current Client Forms" description="Current client forms for Adventure Therapy Services. Request changes to services, complete screening forms, and provide background history.">
  <section class="page-header">
    <div class="container">
      <h1>Current Client Forms</h1>
    </div>
  </section>

  <section class="forms-section">
    <div class="container">
      <div class="forms-grid">
        <div class="form-card">
          <h2>Request to Change Services</h2>
          <p><strong>Purpose:</strong> We understand that you may need to make changes to your ongoing therapy at times. You can use this form to request changes to the type and frequency of OT services to best support you or your child to achieve therapy goals.</p>
          <p><strong>Time to Complete:</strong> 2 - 5 minutes</p>
          <p class="note">Please note you can save and return to this form at anytime.</p>
          <a href="https://form.jotform.com/203617874399066" class="form-btn" target="_blank" rel="noopener noreferrer">Open Form</a>
        </div>

        <!-- Airway and Sleep Screening Form removed — OMT service no longer offered -->

        <div class="form-card">
          <h2>Background History Form</h2>
          <p><strong>Purpose:</strong> Please use this form to assist your clinician to better understand your medical history, current circumstances and goals, allowing more time for discussion in your initial appointment.</p>
          <p><strong>Time to Complete:</strong> 15 - 30 minutes</p>
          <p class="note">Please note you can save and return to this form at anytime.</p>
          <a href="https://form.jotform.com/203607527499061" class="form-btn" target="_blank" rel="noopener noreferrer">Open Form</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-header {
    background: var(--color-primary);
    color: #fff;
    padding: 3rem 0;
    text-align: center;
  }
  .page-header h1 {
    font-size: 2.5rem;
  }
  .forms-section {
    padding: 3rem 0;
  }
  .forms-grid {
    display: grid;
    gap: 2rem;
    max-width: 800px;
    margin: 0 auto;
  }
  .form-card {
    background: #fff;
    border: 1px solid #eee;
    border-radius: 12px;
    padding: 2rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }
  .form-card h2 {
    font-size: 1.3rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }
  .form-card p {
    color: var(--color-text-light);
    line-height: 1.6;
    margin-bottom: 0.75rem;
    font-size: 0.95rem;
  }
  .note {
    font-style: italic;
    font-size: 0.9rem !important;
    color: var(--color-text-light);
  }
  .form-btn {
    display: inline-block;
    background: var(--color-primary);
    color: #fff;
    padding: 0.65rem 1.5rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    margin-top: 0.5rem;
    transition: background 0.2s;
  }
  .form-btn:hover {
    background: var(--color-primary-dark);
  }
</style>
